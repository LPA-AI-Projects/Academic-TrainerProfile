APP_NAME=Trainer Profile API
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8080

LOG_LEVEL=INFO

# Public base URL for export links + Playwright PDF rendering
PUBLIC_BASE_URL=http://127.0.0.1:8080

# Where PDFs are written on disk and served from `/pdfs/{job_id}.pdf`
PDF_STORAGE_DIR=storage/pdfs

# Sync SQLAlchemy uses psycopg2. You may paste postgres:// or postgresql:// from Railway/Supabase;
# settings normalize to postgresql+psycopg2://. Supabase pooler URLs use NullPool automatically.
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/trainer_profiles

DEFAULT_PROVIDER=anthropic
DEFAULT_MODEL=claude-sonnet-4-6

OPENAI_API_KEY=
# When using provider openai without an explicit model (e.g. JSON body model_name).
OPENAI_MODEL=gpt-4.1-mini
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-6

ALLOW_MOCK_GENERATION=true

# Optional: protect API routes with header X-API-Key (Postman / server-to-server).
# When set, browser preview can pass the same value as query param: index.html?job=...&api_key=...
API_SECRET_KEY=

# Zoho CRM OAuth (refresh token flow) or a static ZOHO_ACCESS_TOKEN
# OAuth scopes must include at least: ZohoCRM.modules.READ (record fetch) and
# ZohoCRM.Files.READ (GET /crm/v2/files?id=...). Access tokens expire in ~1 hour; refresh flow is automatic.
#
# Full OAuth + CRM API base URLs (defaults match US/global Zoho stack).
ZOHO_ACCOUNTS_BASE_URL=https://accounts.zoho.com
ZOHO_CRM_API_BASE=https://www.zohoapis.com
#
# Data center suffix (com | in | eu | com.au | ...). Used when deriving hosts if you clear the URLs above.
# Pasting https://www.zohoapis.com into ZOHO_DC alone still normalizes to com.
ZOHO_DC=com
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
# Optional: use instead of refresh flow for quick tests
ZOHO_ACCESS_TOKEN=

# Zoho layout defaults live in app/config.py (Trainers, Trainer_CV, Trainer_Unique_Code, …).
# Override only when your CRM API names differ.
#
# Legacy flow: single Zoho record id → CV on that record (defaults: module Trainers, field Trainer_CV).
# ZOHO_MODULE_API_NAME=
# ZOHO_CV_FIELD_API_NAME=
# Optional second outline PDF on the same record:
# ZOHO_OUTLINE_FIELD_API_NAME=

# Parent-record flow: zoho_record_id is the parent (e.g. course). Set only the parent module API name unless your field names differ from config defaults.
ZOHO_PARENT_MODULE_API_NAME=
# ZOHO_PARENT_OUTLINE_FIELD_API_NAME=Final_Course_Outline
# ZOHO_PARENT_TRAINERS_LOOKUP_FIELD_API_NAME=Trainers
# ZOHO_TRAINER_MODULE_API_NAME=Trainers
# ZOHO_TRAINER_CV_FIELD_API_NAME=Trainer_CV
# ZOHO_TRAINER_UNIQUE_CODE_FIELD_API_NAME=Trainer_Unique_Code
# ZOHO_TRAINER_LOOKUP_RESOLVE_BY_NAME=true
# ZOHO_TRAINER_SEARCH_FIELD_API_NAME=Name

# Google Drive upload (trainer profile PDF):
# Folder structure auto-created/reused:
#   ai_automation / trainer_profile / {course_name}
# Uploaded file name:
#   {unique_code}_{course_name}.pdf
# After POST /generate saves the PDF, also upload to Drive and return google_drive_pdf_url when true:
GOOGLE_DRIVE_AUTO_UPLOAD=false
# Parent CRM field for course folder name when webhook does not send course_name (e.g. Product_Course_Name1).
ZOHO_PARENT_COURSE_NAME_FIELD_API_NAME=Product_Course_Name1
GOOGLE_DRIVE_FALLBACK_COURSE_NAME=Course
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# Optional parent folder id; if empty, uses My Drive root.
GOOGLE_DRIVE_FOLDER_ID=
