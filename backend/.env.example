APP_NAME=Trainer Profile API
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000

LOG_LEVEL=INFO

# Public base URL for export links + Playwright PDF rendering
PUBLIC_BASE_URL=http://127.0.0.1:8000

# Where PDFs are written on disk and served from `/pdfs/{job_id}.pdf`
PDF_STORAGE_DIR=storage/pdfs

DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/trainer_profiles

DEFAULT_PROVIDER=openai
DEFAULT_MODEL=gpt-4.1-mini

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-6

ALLOW_MOCK_GENERATION=true
